{
  "$schema": "https://mintlify.com/docs.json",
  "name": "JJArroyo JavaFX Theme",
  "theme": "willow",
  "colors": {
    "primary": "#2563eb",
    "light": "#dbeafe",
    "dark": "#1d4ed8"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/jjarroyo/javafx-jjarroyo-theme"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/jjarroyo/javafx-jjarroyo-theme"
    }
  },
  "navigation": {
